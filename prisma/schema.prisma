generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String
  passwordHash        String
  status              String?
  onboardingJson      Json?
  healthProfileJson   Json?
  checklistJson       Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

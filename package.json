{
  "name": "zhenskaya-konsultaciya",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:fresh": "powershell -NoProfile -Command \"Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; @('.next','node_modules\\.cache') | ForEach-Object { if (Test-Path $_) { Remove-Item -Recurse -Force $_ } }\" && next dev -p 3000",
    "export:weeks": "py ../scripts/export_weeks_data.py",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "pack:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\pack-for-deploy.ps1"
  },
  "dependencies": {
    "framer-motion": "^12.16.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
